# ── Base de datos ────────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql+asyncpg://dansar:CAMBIA_ESTO@localhost:5432/dansar_prod

# ── JWT ──────────────────────────────────────────────────────
# Genera uno seguro con: openssl rand -hex 32
SECRET_KEY=CAMBIA_ESTO_por_un_string_aleatorio_de_64_caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────
# Para producción: ["https://tu-app.vercel.app"]
# Para demo abierta: ["*"]
ALLOWED_ORIGINS=["*"]

# ── Entorno ──────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Email (opcional) ─────────────────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ── Cloudflare R2 (opcional) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
